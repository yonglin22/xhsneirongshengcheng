# ============================================================
#  赛道智能体操盘台 · 配置模板
#  复制本文件为 .env 并填写。所有 key 只存服务端，不进浏览器。
# ============================================================

# ===== 1) 文本模型（写文案）=====
# 默认推荐：DeepSeek（OpenAI 兼容、支付宝/微信付费、便宜、中文强）
API_FORMAT=openai                                # openai（国产兼容）| anthropic（官方/Anthropic 中转）
ANTHROPIC_BASE_URL=https://api.deepseek.com      # 接口地址（不带 /v1/...）
ANTHROPIC_AUTH_STYLE=bearer                      # bearer（OpenAI 兼容）| x-api-key（Anthropic）
MODEL=deepseek-chat                              # 固定模型；前端不再选模型
ANTHROPIC_API_KEY=sk-你的文本模型key             # platform.deepseek.com → API keys

# --- 换智谱 GLM：ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/paas/v4  MODEL=glm-4-flash
# --- 换 Kimi： ANTHROPIC_BASE_URL=https://api.moonshot.cn/v1  MODEL=moonshot-v1-8k
# --- 用 Anthropic 官方： API_FORMAT=anthropic  ANTHROPIC_BASE_URL=https://api.anthropic.com  ANTHROPIC_AUTH_STYLE=x-api-key  MODEL=（留空用默认）
#     ⚠️ aicodemirror 这类「Claude Code 专用」中转用不了，它只认真·CLI，会拒绝本应用的标准请求。

# ===== 2) 封面图像（S6 一键生图）=====
# 智谱 CogView：cogview-3-flash 免费(带水印)；cogview-4 更好(需充值、无水印)
ZHIPU_API_KEY=你的智谱key                        # open.bigmodel.cn → API keys
ZHIPU_IMAGE_MODEL=cogview-4                       # cogview-4 | cogview-3 | cogview-3-flash(免费)
# 进阶：也可换其它生图服务（代理已支持）
# IMAGE_PROVIDER=siliconflow                       # zhipu(默认) | siliconflow | openai
# IMAGE_BASE_URL=https://api.siliconflow.cn/v1
# IMAGE_API_KEY=sk-...                             # 不填则复用 ZHIPU_API_KEY
# IMAGE_MODEL=Kwai-Kolors/Kolors                   # 不填则用 ZHIPU_IMAGE_MODEL
# IMAGE_SIZE=864x1152                              # 封面 3:4

# ===== 3) 视觉模型（看图：对标封面解析 + S8 图片合规初查）=====
# 复用上面的 ZHIPU_API_KEY，无需另配 key。glm-4v-flash 免费。
ZHIPU_VISION_MODEL=glm-4v-flash                    # glm-4v-flash(免费) | glm-4v(更强)

# ===== 4) 其它（可选）=====
# PORT=8787
# ANTHROPIC_VERSION=2023-06-01
