# 复制本文件为 .env 并填入真实密钥：  cp .env.example .env  然后 nano .env
# 真实密钥从你本地 .env.上线模板 / Render 面板 拷过来。本文件不含任何密钥，可安全进公开仓库。
# server.js 自带 .env 读取（KEY=VALUE，每行一条，# 为注释）。所有 key 只存服务端，不进浏览器。

# —— 基础（非密钥，可直接用）——
NODE_ENV=production
COOKIE_SECURE=true
BILLING_ENABLED=true
PUBLIC_BASE_URL=https://yonglin.chat
SIGNUP_GRANT_CREDITS=200
ADMIN_TOKEN=admin888
ADMIN_PHONES=18268346784

# —— 会话密钥：本地跑 `openssl rand -hex 32` 生成后填这里；★固定写死，变了所有人要重登 ——
SESSION_SECRET=

# —— 1) 文本模型（DeepSeek，OpenAI 兼容格式）——
API_FORMAT=openai
ANTHROPIC_BASE_URL=https://api.deepseek.com
ANTHROPIC_AUTH_STYLE=bearer
MODEL=deepseek-chat
ANTHROPIC_API_KEY=

# —— 2) 智谱（视觉解析 GLM-4V + CogView 兜底）——
ZHIPU_API_KEY=
ZHIPU_IMAGE_MODEL=cogview-4
ZHIPU_VISION_MODEL=glm-4v-flash

# —— 3) Seedream（旧封面/图生图供应商，火山方舟 ark，已切换为下方 GPT image，保留备用）——
SEEDREAM_API_KEY=
SEEDREAM_MODEL=doubao-seedream-5-0-260128
SEEDREAM_SIZE=1728x2304
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# —— 4) GPT image（封面出图，当前默认供应商；走中转就把 BASE_URL 改成中转地址，要到 /v1 这一层）——
GPT_IMAGE_API_KEY=
GPT_IMAGE_MODEL=gpt-image-1
GPT_IMAGE_BASE_URL=https://api.openai.com/v1

# —— 4) 可灵 Kling（内页配图）——
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_BASE_URL=https://api.klingai.com
KLING_MODEL=kling-v1

# —— 5) 可选：Exa 网页搜索 ——
EXA_API_KEY=

# —— 收款/客服：留空即用代码默认 /assets/pay-qr.png 等，无需填 ——
PAY_WECHAT_QR=
SUPPORT_WECHAT_QR=
SUPPORT_WECHAT_ID=
PAY_NOTE=

# —— 真实短信（阿里云；签名/模板审核通过再开，去掉#）——
# SMS_PROVIDER=aliyun
# ALIYUN_SMS_TEMPLATE=SMS_508250151
# ALIYUN_SMS_SIGN=你的签名名称
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=

# —— 抓取：同机模式无需填 COLLECTOR_URL；数据库默认本地 billing.db（VPS 永久磁盘，勿设 TURSO/DB_PATH）——
