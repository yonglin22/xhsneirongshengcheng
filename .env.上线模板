# ===== yonglin.chat 上线模板（无短信版）=====
# 用法：cp .env.上线模板 .env  →  把下面【填】的地方补上  →  bash deploy.sh
# 安全：① 所有 key 换成“轮换后”的新值（旧的已在对话暴露）；② .env 权限 chmod 600

# ---------- 生产开关（已设好，别动）----------
NODE_ENV=production
COOKIE_SECURE=true
BILLING_ENABLED=true
PUBLIC_BASE_URL=https://yonglin.chat
# 会话签名密钥【填】：node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=【填一个64位强随机串】
# 管理后台令牌【填】：换掉 admin888
ADMIN_TOKEN=【填强随机串】
# 管理员手机号（登录后直接进后台）
ADMIN_PHONES=18268346784
# 过渡期防薅：无短信时注册赠分调低；短信上线后改回 200
SIGNUP_GRANT_CREDITS=20

# ---------- 短信：先留空 = 验证码回显模式（登录可用）。批下来再填这几项并重启 ----------
# SMS_PROVIDER=tencent
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_SMS_SDK_APPID=1400xxxxxx
# TENCENT_SMS_SIGN=朱砂操盘台
# TENCENT_SMS_TEMPLATE=2000xxx
# TENCENT_SMS_MINUTES=5

# ---------- AI 服务 key（全部换新值后填）----------
API_FORMAT=openai
ANTHROPIC_BASE_URL=https://api.deepseek.com
ANTHROPIC_AUTH_STYLE=bearer
MODEL=deepseek-chat
ANTHROPIC_API_KEY=【填 DeepSeek 新 key】
ZHIPU_API_KEY=【填 智谱 新 key】
ZHIPU_IMAGE_MODEL=cogview-4
SEEDREAM_API_KEY=【填 火山方舟 新 key】
SEEDREAM_MODEL=doubao-seedream-5-0-260128
SEEDREAM_SIZE=1728x2304
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
KLING_ACCESS_KEY=【填 可灵 新 AK】
KLING_SECRET_KEY=【填 可灵 新 SK】
KLING_BASE_URL=https://api.klingai.com
KLING_MODEL=kling-v1
# 小助手实时网页检索（可留空）
EXA_API_KEY=【填 Exa key 或留空】

# ---------- 支付（一期：扫码 + 客服手动开通）----------
PAY_WECHAT_QR=/assets/pay-qr.png
PAY_NOTE=微信扫码付款后，把「订单号+手机号」发客服，后台开通积分（通常几分钟到账）
SUPPORT_WECHAT_QR=/assets/support-qr.png
SUPPORT_WECHAT_ID=【填你的客服微信号】

# ---------- 艺术资讯（可留默认/留空）----------
ART_DIRECT=1
