/* ============================================================
   FateTell 共享设计系统（水墨极简，移植自 tarot_reader.html）
   ============================================================ */
page {
  --bg: #F4F2EE;
  --bg-raise: #FAF9F6;
  --ink: #1A1815;
  --ink-soft: #56524C;
  --ink-faint: #A8A299;
  --line: #E4E0D8;
  --line-soft: #EDEAE3;
  --amber: #C9A36A;
  --card-back: #26221E;
  --card-back-2: #332E28;
  --face: #FBF9F5;
  --serif: "Songti SC", "STSong", "Noto Serif SC", serif;

  background: var(--bg);
  color: var(--ink);
  font-family: "PingFang SC", "Hiragino Sans GB", system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
}

view, text { box-sizing: border-box; }

.serif { font-family: var(--serif); }

/* ---------- 暖光球 ---------- */
.orb {
  position: fixed;
  width: 560rpx; height: 560rpx; border-radius: 50%;
  background: radial-gradient(circle at 50% 50%,
    rgba(201,163,106,.50) 0%,
    rgba(201,163,106,.20) 35%,
    rgba(201,163,106,0) 70%);
  pointer-events: none; z-index: 0;
  opacity: 0; transition: opacity 1.2s ease;
  top: 120rpx; left: 50%; margin-left: -280rpx;
}
.orb.show { opacity: 1; }
.orb.pulse { animation: breathe 3.4s ease-in-out infinite; }
@keyframes breathe {
  0%,100% { transform: scale(.94); opacity: .82; }
  50% { transform: scale(1.06); opacity: 1; }
}

/* ---------- 页面容器 ---------- */
.screen {
  position: relative; z-index: 1;
  min-height: 100vh;
  padding: 0 56rpx;
  display: flex; flex-direction: column;
}

.brand {
  text-align: center; padding: 28rpx 0 8rpx;
  font-family: var(--serif); font-size: 30rpx; letter-spacing: .34em;
  color: var(--ink); opacity: .85;
}
.eyebrow {
  font-size: 22rpx; letter-spacing: .3em; color: var(--ink-faint);
  text-transform: uppercase;
}
.label {
  font-size: 24rpx; letter-spacing: .2em; color: var(--ink-faint);
  margin-bottom: 24rpx;
}

/* ---------- 领域选择 ---------- */
.domains { display: flex; gap: 22rpx; }
.domain {
  flex: 1; background: var(--bg-raise);
  border: 1rpx solid var(--line); border-radius: 32rpx;
  padding: 40rpx 0 32rpx; text-align: center;
  transition: all .3s ease;
}
.domain .d-char { font-family: var(--serif); font-size: 48rpx; line-height: 1; margin-bottom: 16rpx; }
.domain .d-en { font-size: 18rpx; letter-spacing: .22em; color: var(--ink-faint); text-transform: uppercase; }
.domain.sel { border-color: var(--ink); background: var(--ink); }
.domain.sel .d-char { color: var(--face); }
.domain.sel .d-en { color: rgba(251,249,245,.6); }

/* ---------- 输入框 ---------- */
.field {
  width: 100%; background: transparent;
  border-bottom: 1rpx solid var(--line);
  font-family: var(--serif); font-size: 34rpx; color: var(--ink);
  padding: 26rpx 4rpx; line-height: 1.6; min-height: 150rpx;
}
.field-ph { color: var(--ink-faint); }
.count { text-align: right; font-size: 22rpx; color: var(--ink-faint); margin-top: 8rpx; }

/* ---------- 圆形主按钮 ---------- */
.go-btn {
  width: 120rpx; height: 120rpx; border-radius: 50%; flex-shrink: 0;
  background: var(--ink); padding: 0;
  display: flex; align-items: center; justify-content: center;
  transition: transform .3s, opacity .3s;
}
.go-btn.disabled { opacity: .3; }
.go-btn .arrow {
  width: 36rpx; height: 36rpx;
  border-top: 3rpx solid var(--face); border-right: 3rpx solid var(--face);
  transform: rotate(45deg); margin-left: -8rpx;
}

/* ---------- 通用胶囊按钮 ---------- */
.btn {
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--serif); font-size: 28rpx; letter-spacing: .08em;
  padding: 26rpx 56rpx; border-radius: 60rpx; background: var(--ink); color: var(--face);
}
.btn.ghost { background: transparent; color: var(--ink); border: 1rpx solid var(--ink); }
.btn.block { display: flex; width: 100%; }
.btn-hover { opacity: .82; }

/* ---------- 塔罗牌（牌背 / 翻牌 / 牌面） ---------- */
.cards-row { display: flex; justify-content: center; gap: 20rpx; perspective: 1600rpx; }
.card {
  width: 188rpx; height: 312rpx; position: relative;
  opacity: 0; transform: translateY(28rpx);
  transition: opacity .6s ease, transform .6s cubic-bezier(.2,.8,.2,1);
}
.card.in { opacity: 1; transform: translateY(0); }
.card-inner {
  position: absolute; inset: 0; transform-style: preserve-3d;
  transition: transform 1.05s cubic-bezier(.16,1,.3,1);
}
.card.flip .card-inner { transform: rotateY(180deg); }
.card-back, .card-face {
  position: absolute; inset: 0; backface-visibility: hidden;
  border-radius: 20rpx; overflow: hidden;
}
.card-back {
  background: radial-gradient(120% 80% at 50% -10%, var(--card-back-2), var(--card-back));
  border: 1rpx solid #1d1916;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 16rpx 44rpx rgba(30,26,22,.18);
}
.cb-mark {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  border: 1rpx solid rgba(232,226,216,.4); position: relative;
}
.card-face {
  background: var(--face); transform: rotateY(180deg);
  border: 1rpx solid var(--line);
  box-shadow: 0 18rpx 48rpx rgba(30,26,22,.13);
  display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 14rpx 20rpx;
}
.cf-pos { font-size: 20rpx; letter-spacing: .2em; color: var(--ink-faint); }
.cf-glyph { font-family: var(--serif); font-size: 84rpx; line-height: 1; color: var(--line); margin: 28rpx 0 auto; }
.cf-glyph.rev { transform: rotate(180deg); }
.cf-name { font-family: var(--serif); font-size: 34rpx; letter-spacing: .06em; margin-bottom: 8rpx; }
.cf-ori { font-size: 21rpx; letter-spacing: .12em; color: var(--ink-soft); display: flex; align-items: center; gap: 8rpx; }
.cf-ori .dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: var(--amber); }
.cf-ori.rev .dot { background: var(--ink-faint); }

/* ---------- 解读区块 ---------- */
.sec { margin-top: 64rpx; }
.sec-label {
  font-size: 22rpx; letter-spacing: .26em; color: var(--ink-faint);
  text-transform: uppercase; margin-bottom: 28rpx;
  display: flex; align-items: center;
}
.sec-label .ln { flex: 1; height: 1rpx; background: var(--line-soft); margin-left: 22rpx; }
.situation { font-family: var(--serif); font-size: 42rpx; line-height: 1.5; }
.perspective { font-size: 30rpx; line-height: 1.95; color: var(--ink-soft); }

.ins { display: flex; padding: 30rpx 0; border-top: 1rpx solid var(--line-soft); }
.ins:first-child { border-top: none; }
.ins-n { font-family: var(--serif); font-size: 28rpx; color: var(--ink-faint); width: 44rpx; flex-shrink: 0; }
.ins-t { font-size: 29rpx; line-height: 1.8; color: var(--ink); flex: 1; }

.action-card { background: var(--ink); color: var(--face); border-radius: 36rpx; padding: 46rpx 44rpx; }
.action-card .ac-label { font-size: 21rpx; letter-spacing: .26em; color: rgba(251,249,245,.5); text-transform: uppercase; margin-bottom: 22rpx; }
.action-card .ac-text { font-family: var(--serif); font-size: 33rpx; line-height: 1.65; }

/* ---------- 免责声明 ---------- */
.disclaimer {
  font-size: 22rpx; line-height: 1.8; color: var(--ink-faint);
  margin-top: 40rpx; padding-top: 32rpx; border-top: 1rpx solid var(--line-soft);
}

/* ---------- 渐显动效 ---------- */
.reveal { opacity: 0; transform: translateY(28rpx); transition: opacity .8s ease, transform .8s cubic-bezier(.2,.8,.2,1); }
.reveal.in { opacity: 1; transform: translateY(0); }

/* ---------- 卡片/列表通用 ---------- */
.panel { background: var(--bg-raise); border: 1rpx solid var(--line); border-radius: 28rpx; padding: 36rpx; }
.row { display: flex; align-items: center; justify-content: space-between; }
.muted { color: var(--ink-faint); }
.divider { height: 1rpx; background: var(--line-soft); }
