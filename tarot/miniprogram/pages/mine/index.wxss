.mine { padding-top: 32rpx; padding-bottom: 80rpx; }

.w-label { font-size: 24rpx; margin-bottom: 14rpx; }
.w-balance { font-size: 76rpx; line-height: 1; }
.w-streak { font-size: 24rpx; margin-top: 28rpx; }

.tabs { display: flex; gap: 44rpx; margin: 52rpx 0 8rpx; }
.tab { font-size: 28rpx; color: var(--ink-faint); padding-bottom: 14rpx; }
.tab.on { color: var(--ink); border-bottom: 3rpx solid var(--ink); }

.empty { text-align: center; padding: 90rpx 0; font-size: 26rpx; }

.hist-item { padding: 34rpx 0; border-bottom: 1rpx solid var(--line-soft); }
.hi-domain { font-family: var(--serif); font-size: 28rpx; }
.hi-when { font-size: 22rpx; }
.hi-head { font-size: 28rpx; color: var(--ink-soft); margin-top: 16rpx; line-height: 1.6; }

.led-item { padding: 30rpx 0; border-bottom: 1rpx solid var(--line-soft); }
.le-type { font-size: 28rpx; }
.le-right { text-align: right; }
.le-amt { font-size: 30rpx; font-family: var(--serif); }
.le-when { font-size: 22rpx; margin-top: 8rpx; }

.private { text-align: center; margin-top: 56rpx; }
.pv-t { font-size: 32rpx; margin-bottom: 14rpx; }
.pv-d { font-size: 24rpx; line-height: 1.7; margin-bottom: 20rpx; }
.pv-wx { font-size: 27rpx; color: var(--amber); }
