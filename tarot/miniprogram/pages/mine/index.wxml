<view class="screen mine">
  <view class="wallet panel">
    <view class="row">
      <view>
        <view class="w-label muted">我的积分</view>
        <view class="w-balance serif">{{balance}}</view>
      </view>
      <view class="btn" bindtap="goRecharge" hover-class="btn-hover">充值</view>
    </view>
    <view class="w-streak muted">连续签到 {{streak}} 天</view>
  </view>

  <view class="tabs">
    <view class="tab {{tab==='history'?'on':''}}" bindtap="switchTab" data-t="history">解读记录</view>
    <view class="tab {{tab==='ledger'?'on':''}}" bindtap="switchTab" data-t="ledger">积分明细</view>
  </view>

  <block wx:if="{{tab==='history'}}">
    <view wx:if="{{readings.length===0}}" class="empty muted">还没有解读记录，去问一事吧。</view>
    <view wx:for="{{readings}}" wx:key="id" class="hist-item" bindtap="openReading" data-id="{{item.id}}">
      <view class="row">
        <view class="hi-domain">{{item.domain}}</view>
        <view class="hi-when muted">{{item.when}}{{item.fav ? ' · ★' : ''}}</view>
      </view>
      <view class="hi-head">{{item.head}}</view>
    </view>
  </block>

  <block wx:else>
    <view wx:if="{{ledger.length===0}}" class="empty muted">暂无积分流水。</view>
    <view wx:for="{{ledger}}" wx:key="when" class="led-item row">
      <view class="le-type">{{item.type}}</view>
      <view class="le-right">
        <view class="le-amt">{{item.amount}}</view>
        <view class="le-when muted">{{item.when}}</view>
      </view>
    </view>
  </block>

  <view class="private panel">
    <view class="pv-t serif">加我，聊得更深</view>
    <view class="pv-d muted">更深的牌阵与 1 对 1 解读，加微信解锁。</view>
    <view class="pv-wx" bindtap="copyWechat">微信：{{serviceWechat}}（点此复制）</view>
  </view>
</view>
