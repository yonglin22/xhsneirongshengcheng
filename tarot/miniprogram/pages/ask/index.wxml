<view class="screen ask">
  <view class="brand">FATETELL ·</view>

  <view class="hero serif">问一事，</view>
  <view class="hero serif">看清此刻</view>
  <view class="hero-sub">塔罗不预言你的未来。它是一面镜子，照见你当下真正的处境，把选择权留给你。</view>

  <view class="label">想问哪一面</view>
  <view class="domains">
    <view
      wx:for="{{domains}}"
      wx:key="k"
      class="domain {{domain===item.k?'sel':''}}"
      bindtap="pickDomain"
      data-k="{{item.k}}">
      <view class="d-char">{{item.k}}</view>
      <view class="d-en">{{item.en}}</view>
    </view>
  </view>

  <view class="label" style="margin-top:64rpx">你最近在纠结什么</view>
  <textarea
    class="field"
    placeholder="把具体的事说出来，越具体，照得越清…"
    placeholder-class="field-ph"
    maxlength="200"
    value="{{situation}}"
    bindinput="onInput"
    auto-height />
  <view class="count">{{situation.length}}/200</view>

  <view class="go-row">
    <view class="go-hint muted">默契抽三张牌：现状 · 阻碍 · 指引</view>
    <view class="go-btn {{canGo?'':'disabled'}}" bindtap="go" hover-class="{{canGo?'btn-hover':''}}">
      <view class="arrow"></view>
    </view>
  </view>

  <view class="balance-line muted">当前积分 {{balance}} · 深度解读 {{price}}/次</view>

  <view class="disclaimer">仅供自我觉察与决策参考，不构成任何确定性预测或投资建议。怎么走，始终由你决定。</view>
</view>
