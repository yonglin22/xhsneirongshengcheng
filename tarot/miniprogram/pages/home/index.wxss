.home { padding-top: 8rpx; padding-bottom: 80rpx; }
.hint { text-align: center; margin-top: 220rpx; font-size: 28rpx; }

.today-head { display: flex; align-items: center; justify-content: space-between; margin: 44rpx 0 32rpx; }
.streak { font-size: 24rpx; color: var(--amber); letter-spacing: .05em; }

.today-card { display: flex; justify-content: center; margin-bottom: 52rpx; }
.today-card .card { width: 248rpx; height: 412rpx; }
.today-card .cf-glyph { font-size: 116rpx; }
.today-card .cf-name { font-size: 42rpx; }

.tip { text-align: center; font-size: 40rpx; line-height: 1.6; padding: 0 12rpx; }

.yj { display: flex; align-items: center; justify-content: center; margin: 52rpx 0; }
.yj-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; min-width: 150rpx; }
.yj-k { font-size: 22rpx; color: var(--ink-faint); letter-spacing: .2em; }
.yj-v { font-family: var(--serif); font-size: 34rpx; }
.yj-sep { width: 1rpx; height: 60rpx; background: var(--line); }

.cta { margin-top: 16rpx; }
.cta-line { text-align: center; font-size: 26rpx; margin-bottom: 24rpx; }
