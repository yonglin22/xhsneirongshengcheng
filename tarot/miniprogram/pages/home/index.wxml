<view class="orb {{orbOn?'show':''}}"></view>

<view class="screen home">
  <view class="brand">FATETELL ·</view>

  <view wx:if="{{loading}}" class="hint muted">正在为你抽今日的牌…</view>
  <view wx:elif="{{error}}" class="hint muted">{{error}}</view>

  <block wx:else>
    <view class="today-head">
      <view class="eyebrow">TODAY · 今日牌</view>
      <view wx:if="{{streak>0}}" class="streak">连签 {{streak}} 天</view>
    </view>

    <view class="today-card">
      <view class="card in flip">
        <view class="card-inner">
          <view class="card-back"><view class="cb-mark"></view></view>
          <view class="card-face">
            <view class="cf-pos">{{sign.card.position}}</view>
            <view class="cf-glyph {{sign.card.reversed?'rev':''}}">{{sign.card.mark}}</view>
            <view class="cf-name">{{sign.card.name}}</view>
            <view class="cf-ori {{sign.card.reversed?'rev':''}}"><view class="dot"></view>{{sign.card.reversed?'逆位':'正位'}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="tip serif">{{sign.tip}}</view>

    <view class="yj">
      <view class="yj-item"><view class="yj-k">宜</view><view class="yj-v">{{sign.yi}}</view></view>
      <view class="yj-sep"></view>
      <view class="yj-item"><view class="yj-k">忌</view><view class="yj-v">{{sign.ji}}</view></view>
      <view class="yj-sep"></view>
      <view class="yj-item"><view class="yj-k">能量</view><view class="yj-v">{{sign.energy}}</view></view>
    </view>

    <view class="cta">
      <view class="cta-line muted">心里有正纠结的事？</view>
      <view class="btn block" bindtap="goAsk" hover-class="btn-hover">问一事，看清此刻 →</view>
    </view>

    <view class="disclaimer">每日一签仅供自我觉察与提点，不构成确定性预测。</view>
  </block>
</view>
