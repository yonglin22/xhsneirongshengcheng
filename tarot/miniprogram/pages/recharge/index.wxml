<view class="screen recharge">
  <view class="rc-balance">
    <view class="muted rc-cap">当前积分</view>
    <view class="serif rc-num">{{balance}}</view>
  </view>

  <view class="packs">
    <view
      wx:for="{{packs}}"
      wx:key="id"
      class="pack"
      bindtap="buy"
      data-id="{{item.id}}"
      hover-class="pack-hover">
      <view class="pk-left">
        <view class="pk-credits serif">{{item.credits}} 积分</view>
        <view class="pk-label muted">{{item.label}}{{item.tag ? ' · ' + item.tag : ''}}</view>
      </view>
      <view class="pk-price serif">¥{{item.cny}}</view>
    </view>
  </view>

  <view wx:if="{{mock}}" class="mock-note">当前为「模拟支付」联调模式：点击即到账，不走真实扣款。上线前在 config.js 把 mockPay 改为 false。</view>

  <view class="disclaimer">积分为虚拟内容，用于解锁深度解读等服务，一经消耗不予退还。充值即视为同意该说明。</view>
</view>
