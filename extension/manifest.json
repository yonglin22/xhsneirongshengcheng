{
  "manifest_version": 3,
  "name": "朱砂操盘台 · 小红书采集&发布助手",
  "version": "0.8.0",
  "description": "用你本机已登录的小红书：①抓真实对标笔记（不限次、不被机房IP风控）②抓博主粉丝数③成稿一键存草稿箱。全程本机真实会话，零风控。",
  "permissions": ["tabs", "storage", "scripting", "alarms", "notifications"],
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" },
  "host_permissions": [
    "https://yonglin.chat/*",
    "http://yonglin.chat/*",
    "https://*.xiaohongshu.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["https://yonglin.chat/*", "http://yonglin.chat/*"], "js": ["bridge.js"], "run_at": "document_idle" },
    { "matches": ["https://creator.xiaohongshu.com/*"], "js": ["xhs.js"], "run_at": "document_idle" },
    { "matches": ["https://www.xiaohongshu.com/*"], "js": ["nurture.js"], "run_at": "document_idle" }
  ],
  "action": { "default_popup": "popup.html", "default_title": "朱砂 · 小红书发布助手", "default_icon": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" } }
}
